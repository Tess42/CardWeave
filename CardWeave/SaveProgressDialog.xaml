<Window x:Class="CardWeave.SaveProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save" 
        Width="300" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <TextBlock TextAlignment="Center" VerticalAlignment="Center">
            <Run Text="You have unsaved progress."/>
            <LineBreak/>
            <Run Text="Do you want to save before closing?"/>
        </TextBlock>

        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Yes button -->
            <Button Grid.Column="0" Content="Yes" Margin="0,0,10,0" Style="{StaticResource Button}" Click="Yes_Click"/>

            <!-- No button -->
            <Button Grid.Column="1" Content="No" Margin="5,0,5,0" Style="{StaticResource Button}" Click="No_Click"/>

            <!-- Cancel button -->
            <Button Grid.Column="2" Content="Cancel" Margin="10,0,0,0" Style="{StaticResource Button}" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
