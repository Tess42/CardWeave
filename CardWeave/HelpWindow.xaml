<Window x:Class="CardWeave.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help" 
        Height="660" Width="1000"
        Background="{StaticResource BackgroundColor}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <!-- Left sidebar with topics -->
            <ColumnDefinition Width="200"/>
            <!-- Right content area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ScrollBar}"
                                       Orientation="Vertical"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,-5,0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/> 
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>

                <StackPanel>
                    <Button Content="Getting Started" Tag="getting_started" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left" Click="Topic_Click" Margin="0,0,0,10"/>
                    <Button Content="Band Settings" Tag="band_settings" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left" Click="Topic_Click" Margin="0,0,0,10"/>
                    <Button Content="Modifying Tablets" Tag="modifying_tablets" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left" Click="Topic_Click" Margin="0,0,0,10"/>
                    <Button Content="Colors" Tag="colors" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="Threading" Tag="threading" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="Turning" Tag="turning" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="Visualization" Tag="visualization" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="File Operations" Tag="file_operations" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="Weaving Guide" Tag="weaving_guide" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Button Content="Keyboard Shortcuts" Tag="shortcuts" Style="{StaticResource ToolbarButtonStyle}" Click="Topic_Click" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Content Area -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ScrollBar}"
                                       Orientation="Vertical"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,-5,0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                
                <TextBlock x:Name="ContentTextBlock" TextWrapping="Wrap" LineHeight="22"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>