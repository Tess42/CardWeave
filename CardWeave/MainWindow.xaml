<Window x:Class="CardWeave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Card Weave"
        Height="660" Width="1000"
        Background="{StaticResource BackgroundColor}"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <!-- Main layout -->
    <Grid x:Name="MainGrid" Margin="12" Focusable="True" MouseDown="EmptySpace_MouseDown">

        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="55"/>
            <!-- Rest of the window -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Left panel -->
            <ColumnDefinition Width="300"/>
            <!-- Band visualization -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource ToolbarCard}">
            <StackPanel Orientation="Horizontal" Margin="10,0">

                <!-- File -->
                <Button Content="File" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="New" Style="{StaticResource MenuItem}" Click="NewBand_Click"/>
                            <MenuItem Header="Save" Style="{StaticResource MenuItem}" Click="SaveBand_Click"/>
                            <MenuItem Header="Save as" Style="{StaticResource MenuItem}" Click="SaveBandAs_Click"/>
                            <MenuItem Header="Open..." Style="{StaticResource MenuItem}" Click="OpenBand_Click"/>
                            <MenuItem Header="Export as image" Style="{StaticResource MenuItem}" Click="ExportPatternAsImage_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Edit -->
                <Button Content="Edit" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="Undo" Style="{StaticResource MenuItem}" Click="Undo_Click"/>
                            <MenuItem Header="Redo" Style="{StaticResource MenuItem}" Click="Redo_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- View -->
                <Button Content="View" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="Show front/back side of the band" Style="{StaticResource MenuItem}" Click="BandSide_Click"/>
                            <MenuItem Header="Show/hide column numbers" Style="{StaticResource MenuItem}" Click="ColumnLabeling_Click"/>
                            <MenuItem Header="Show/hide row numbers" Style="{StaticResource MenuItem}" Click="RowLabeling_Click"/>
                            <MenuItem Header="Show/hide hole label column" Style="{StaticResource MenuItem}" Click="HoleLabeling_Click"/>
                            <MenuItem Header="Show/hide hole labels in grid" Style="{StaticResource MenuItem}" Click="GridHoleLabeling_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Turning -->
                <Button Content="Turning" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="Reverse all turning" Style="{StaticResource MenuItem}" Click="ReverseAllTurning_Click"/>
                            <MenuItem Header="Set all to forward" Style="{StaticResource MenuItem}" Click="SetAllToForward_Click"/>
                            <MenuItem Header="Set all to backward" Style="{StaticResource MenuItem}" Click="SetAllToBackward_Click"/>
                            <MenuItem Header="Alternate forward/backward" Style="{StaticResource MenuItem}" Click="AlternateForwardBackward_Click"/>
                            <MenuItem Header="2 forward / 2 backward" Style="{StaticResource MenuItem}" Click="Alternate2Forward2Backward_Click"/>
                            <MenuItem Header="4 forward / 4 backward" Style="{StaticResource MenuItem}" Click="Alternate4Forward4Backward_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Threading -->
                <Button Content="Threading" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="Reverse all threading" Style="{StaticResource MenuItem}" Click="ReverseAllThreading_Click"/>
                            <MenuItem Header="Set all to S‑threading" Style="{StaticResource MenuItem}" Click="SetAllThreadingToS_Click"/>
                            <MenuItem Header="Set all to Z‑threading" Style="{StaticResource MenuItem}" Click="SetAllThreadingToZ_Click"/>
                            <MenuItem Header="Halved threading" Style="{StaticResource MenuItem}" Click="SetHalvedThreading_Click"/>
                            <MenuItem Header="Alternate S and Z threading" Style="{StaticResource MenuItem}" Click="AlternateSZThreading_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Colors -->
                <Button Content="Colors" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource ContextMenu}">
                            <MenuItem Header="Set all to currently picked color" Style="{StaticResource MenuItem}" Click="AllToPickedColor_Click"/>
                            <MenuItem Header="Shuffle band colors" Style="{StaticResource MenuItem}" Click="ShuffleBandColors_Click"/>
                            <MenuItem Header="Set band background to currently picked color" Style="{StaticResource MenuItem}" Click="BackgroundColor_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Presets -->
                <Button Content="Presets" Style="{StaticResource ToolbarButtonStyle}" Click="OpenMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="PresetsMenu" Style="{StaticResource ContextMenu}"/>
                    </Button.ContextMenu>
                </Button>

                <!-- Weaving Guide -->
                <Button Content="Weaving guide" Style="{StaticResource ToolbarButtonStyle}" Click="StartGuide_Click"/>

                <!-- Help -->
                <Button Content="Help" Style="{StaticResource ToolbarButtonStyle}" Click="Help_Click"/>

            </StackPanel>
        </Border>

        <!-- Left panel -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <!-- Band settings -->
                <RowDefinition Height="Auto"/>
                <!-- Modify tablets -->
                <RowDefinition Height="Auto"/>
                <!-- Color -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Band settings -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Band settings" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Number of holes -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Number of holes" VerticalAlignment="Center"/>
                        <ComboBox x:Name="NumberOfHolesComboBox" Grid.Column="1" Style="{StaticResource ComboBox}" Tag="Bottom" SelectionChanged="NumberOfHolesComboBox_SelectionChanged"/>
                    </Grid>

                    <!-- Number of tablets -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Number of tablets" VerticalAlignment="Center"/>
                        <TextBox x:Name="NumberOfTabletsTextBox" Grid.Column="1" FontSize="14" Style="{StaticResource TextBox}" KeyDown="TextBox_KeyDown" LostKeyboardFocus="NumberOfTabletsTextBox_LostKeyboardFocus"/>
                    </Grid>

                    <!-- Number of rows -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Number of rows" VerticalAlignment="Center"/>
                        <TextBox x:Name="NumberOfRowsTextBox" Grid.Column="1" FontSize="14" Style="{StaticResource TextBox}" KeyDown="TextBox_KeyDown" LostKeyboardFocus="NumberOfRowsTextBox_LostKeyboardFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Modify tablets -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Modify tablets" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Add tablet -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Add tablet on position" VerticalAlignment="Center"/>
                        <TextBox x:Name="AddTabletTextBox" Grid.Column="1" FontSize="14" Style="{StaticResource TextBox}" KeyDown="TextBox_KeyDown" LostKeyboardFocus="AddTabletTextBox_LostKeyboardFocus"/>
                    </Grid>

                    <!-- Remove tablet -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Remove tablet on position" VerticalAlignment="Center"/>
                        <TextBox x:Name="RemoveTabletTextBox" Grid.Column="1" FontSize="14" Style="{StaticResource TextBox}" KeyDown="TextBox_KeyDown" LostKeyboardFocus="RemoveTabletTextBox_LostKeyboardFocus"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Color -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Color" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Currently picked color -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Currently picked color" VerticalAlignment="Center"/>
                        <Border x:Name="ActiveColor" Style="{StaticResource ColorSlot}" Cursor="Arrow" Margin="0,-3,0,0" Grid.Column="1">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding CurrentColor, Mode=TwoWay}"/>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <UniformGrid x:Name="ColorSlotsPanel" Rows="2" Columns="8" Margin="0,0,0,10">
                        <!-- Row 1 -->
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>

                        <!-- Row 2 -->
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>
                        <Border Style="{StaticResource ColorSlot}" MouseLeftButtonUp="ColorSlot_Click"/>

                        <Border Style="{StaticResource ColorSlot}" Background="#FFFFFF" MouseLeftButtonUp="AddColor_Click">
                            <TextBlock Text="+" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </UniformGrid>

                    <!-- Band color palette -->
                    <TextBlock Text="Band color palette" Margin="0,0,0,10"/>

                    <UniformGrid x:Name="BandPaletteGrid" Rows="1"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Band visualization -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
            <Grid x:Name="PatternVisualization" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="TabletDirectionScroll"
                              Grid.Row="0"
                              Margin="30,0,30,0"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Hidden">

                    <Grid Name="TabletDirectionRow" HorizontalAlignment="Center"/>
                </ScrollViewer>

                <Grid Grid.Row="1" HorizontalAlignment="Center">
                    <ScrollViewer x:Name="ColorPickingGridScroll"
                                  Margin="30,0,30,0"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Hidden">

                        <Grid Name="ColorPickingGrid"/>
                    </ScrollViewer>

                    <Grid Name="HoleLabelGrid" Margin="10,0,0,0"/>
                </Grid>

                <ScrollViewer x:Name="TabletNumberRowScroll"
                              Grid.Row="2"
                              Margin="30,10,30,0"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Hidden"
                              IsHitTestVisible="False">

                    <Grid Name="TabletNumberRow" HorizontalAlignment="Center"/>
                </ScrollViewer>

                <TextBlock x:Name="BackSideLabel" Text = "Back side" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Bottom" Visibility="Collapsed"/>

                <Grid Grid.Row="4" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <ScrollViewer x:Name="BandScrollViewer" 
                                  Margin="30,0,30,20" 
                                  PanningMode="None" 
                                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Auto"
                                  ScrollChanged="BandScrollViewer_ScrollChanged">
                        <ScrollViewer.Template>
                            <ControlTemplate TargetType="ScrollViewer">
                                <Grid>
                                    <ScrollContentPresenter/>

                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                               Style="{StaticResource ScrollBar}"
                                               Orientation="Vertical"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,-20,0"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Value="{TemplateBinding VerticalOffset}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>

                                    <ScrollBar x:Name="PART_HorizontalScrollBar"
                                               Style="{StaticResource ScrollBar}"
                                               Orientation="Horizontal"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,-20"
                                               Maximum="{TemplateBinding ScrollableWidth}"
                                               ViewportSize="{TemplateBinding ViewportWidth}"
                                               Value="{TemplateBinding HorizontalOffset}"
                                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                </Grid>
                            </ControlTemplate>
                        </ScrollViewer.Template>

                        <Grid>
                            <Grid Name="BandVisualizationGrid"/>
                        </Grid>
                    </ScrollViewer>

                    <ScrollViewer x:Name="RowNumberScroll" 
                                  Margin="0,0,0,20" 
                                  PanningMode="None" 
                                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsHitTestVisible="False">

                        <Grid Name="RowNumberGrid"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Error message -->
        <Grid x:Name="ErrorMessage" 
              Grid.Row="0" 
              Grid.ColumnSpan="2"
              VerticalAlignment="Top"
              HorizontalAlignment="Right"
              IsHitTestVisible="False"/>
        </Grid>
</Window>
